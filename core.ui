  <property name="styleSheet">
   <string notr="true">/* Main Window */
QMainWindow {
    background-color: rgb(0, 55, 107);
}

/* Sidebar */
#sidebar {
    background-color: #1a3a52;
    border-right: 3px solid #0d7377;
}

#lblTitle {
    color: #ffffff;
    font-size: 18px;
    font-weight: bold;
    padding: 10px;
}

/* Common Button Style (Base) */
QPushButton {
    border: none;
    border-radius: 5px;
    font-size: 14px;
    font-weight: 500;
}

/* Sidebar Buttons */
#sidebar QPushButton {
    background-color: #2c5f7d;
    color: #ffffff;
    padding: 15px 20px;
    text-align: left;
    margin: 5px 10px;
    border-left: 4px solid transparent;
}

#sidebar QPushButton:hover {
    background-color: #3e7a9e;
    border-left: 4px solid #14ffec;
}

#sidebar QPushButton:checked {
    background-color: #0d7377;
    border-left: 6px solid #14ffec;
    font-weight: bold;
}

/* Sub-navigation Bar Container */
#subNavBar {
    background-color: transparent;
}

/* Sub-navigation Buttons */
#subNavBar QPushButton {
    background-color: #2c5f7d;
    color: #ffffff;
    padding: 8px 15px;
    text-align: center;
    margin: 5px;
    min-width: 120px;
    border-bottom: 3px solid transparent;
}

#subNavBar QPushButton:hover {
    background-color: #3e7a9e;
    border-bottom: 3px solid #14ffec;
}

#subNavBar QPushButton:checked {
    background-color: #0d7377;
    border-bottom: 4px solid #14ffec;
    font-weight: bold;
}

/* Pecheur Sub-navigation Bar */
#subNavBarPecheurs {
    background-color: transparent;
}

#subNavBarPecheurs QPushButton {
    background-color: #2c5f7d;
    color: #ffffff;
    padding: 8px 15px;
    text-align: center;
    margin: 5px;
    min-width: 120px;
    border-bottom: 3px solid transparent;
}

#subNavBarPecheurs QPushButton:hover {
    background-color: #3e7a9e;
    border-bottom: 3px solid #14ffec;
}

#subNavBarPecheurs QPushButton:checked {
    background-color: #0d7377;
    border-bottom: 4px solid #14ffec;
    font-weight: bold;
}

/* Page Titles */
.pageTitle {
    color: #1a3a52;
    font-size: 28px;
    font-weight: bold;
}

.subPageTitle {
    color: #2c5f7d;
    font-size: 24px;
    font-weight: 600;
}</string>
