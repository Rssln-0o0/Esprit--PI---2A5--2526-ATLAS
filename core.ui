    background-color: #1e5f74;
    color: white;
    padding: 5px;
    border: none;
    font-weight: bold;
}

QGroupBox {
    color: #2a9d8f;
    font-weight: bold;
    border: 2px solid #2a9d8f;
    border-radius: 5px;
    margin-top: 10px;
    padding-top: 10px;
}

