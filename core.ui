               <property name="styleSheet">
                <string notr="true">QTabWidget::pane { border: 1px solid #3498db; background-color: #232323; border-radius: 5px; }
QTabBar::tab { background: #2d2d2d; color: #ffffff; padding: 10px; border-top-left-radius: 5px; border-top-right-radius: 5px; border: 1px solid #3d3d3d; width: 150px;}
QTabBar::tab:selected { background: #3498db; }
/* Global Widget Styles for this Tab */
QWidget {
    font-family: &quot;Segoe UI&quot;;
}
QLabel {
    color: #ffffff;
    font-weight: bold;
    font-size: 12px;
}
QLineEdit, QComboBox, QDateEdit, QSpinBox, QDoubleSpinBox { 
    color: white; 
    background-color: #2d2d2d; 
    border: 1px solid #3d3d3d; 
    padding: 5px; 
    border-radius: 4px; 
}
QPushButton {
    background-color: #3498db;
    color: white;
    border: none;
    padding: 8px 16px;
    border-radius: 4px;
    font-weight: bold;
}
QPushButton:hover {
    background-color: #2980b9;
}
QPushButton:pressed {
    background-color: #1abc9c;
}
QTableWidget {
    background-color: #2b2b2b;
    color: white;
    gridline-color: #555;
    border: 1px solid #3d3d3d;
}
QHeaderView::section {
    background-color: #34495e;
    color: white;
    padding: 5px;
    border: none;
}</string>
