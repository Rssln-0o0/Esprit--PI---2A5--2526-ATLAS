            <item>
             <widget class="QTabWidget" name="tabWidget">
              <property name="styleSheet">
               <string notr="true">QTabWidget::pane { border: 1px solid #3498db; background-color: #232323; border-radius: 5px; }
QTabBar::tab { background: #2d2d2d; color: #ffffff; padding: 10px; border-top-left-radius: 5px; border-top-right-radius: 5px; border: 1px solid #3d3d3d; width: 150px;}
QTabBar::tab:selected { background: #3498db; }
/* Global Widget Styles for this Tab */
QWidget {
    font-family: &quot;Segoe UI&quot;;
}
QLabel {
}

/* Radio Buttons */
QRadioButton {
    background-color: transparent;
    color: #e0e0e0;
    font-size: 13px;
}
QRadioButton::indicator {
    width: 14px;
    height: 14px;
    border-radius: 8px;
    border: 2px solid #3b9ddd;
    background-color: transparent;
}
QRadioButton::indicator:checked {
    background-color: #3b9ddd;
    border: 2px solid #3b9ddd;
}

/* GroupBox (Container) */
QGroupBox {
    border: 2px solid #3b9ddd;
    border-radius: 8px;
    margin-top: 10px;
    background-color: #212121;
    font-weight: bold;
    color: #3b9ddd; 
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top center;
    padding: 0 10px;
    background-color: #212121;
}

/* Inputs */
QLineEdit, QComboBox, QDateEdit, QSpinBox, QPlainTextEdit {
    background-color: #2d2d2d;
    border: 1px solid #3d3d3d;
    border-radius: 6px;
    padding: 8px;
    color: #ffffff;
    min-height: 25px;
}
QLineEdit:focus, QComboBox:focus, QDateEdit:focus {
    border: 1px solid #3b9ddd;
    background-color: #353535;
}

/* Buttons */
QPushButton {
    background-color: #3b9ddd;
    color: white;
    border-radius: 6px;
    padding: 10px 20px;
    font-weight: bold;
    border: none;
}
QPushButton:hover {
    background-color: #4da8e0;
}
QPushButton:pressed {
    background-color: #2d8ac7;
}

/* Specific Button Colors */
QPushButton#pushButton_3 { /* Delete */
    background-color: #c0392b;
}
QPushButton#pushButton_3:hover {
    background-color: #e74c3c;
}

QPushButton#pushButton_4 { /* Export */
    background-color: #f39c12;
}
QPushButton#pushButton_4:hover {
    background-color: #f5b041;
}

/* Table Widget */
QTableWidget {
    background-color: #212121;
    alternate-background-color: #2a2a2a;
    gridline-color: #3d3d3d;
    border: 2px solid #3b9ddd;
    border-radius: 8px;
    color: #e0e0e0;
}
QTableWidget::item:selected {
    background-color: #3b9ddd;
    color: white;
}
QHeaderView::section {
    background-color: #2d2d2d;
    color: #ffffff;
    padding: 8px;
    border: none;
    border-bottom: 2px solid #3b9ddd;
    font-weight: bold;
}

/* Frames */
QFrame#chartContainer, QFrame#chartContainer_2 {
    border: 2px solid #3b9ddd;
    border-radius: 8px;
    background-color: #212121;
}

/* Chart View */
QChartView {
    background-color: transparent;
}

/* Menus */
QMenuBar {
    background-color: #1a1a1a;
    color: #e0e0e0;
}
QMenuBar::item:selected {
    background-color: #3b9ddd;
    color: white;
}
QStatusBar {
    background-color: #1a1a1a;
    color: #e0e0e0;
}</string>
