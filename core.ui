          <property name="styleSheet">
           <string notr="true">QMainWindow {
    background-color: #3a3a3a;
}

QPushButton {
    background-color: #2a9d8f;
    color: white;
    border: none;
    padding: 10px;
    font-weight: bold;
    border-radius: 5px;
}

QPushButton:hover {
    background-color: #21867a;
}

QPushButton:pressed {
    background-color: #1e5f74;
}

QTabWidget::pane {
    border: 2px solid #2a9d8f;
    background-color: #2b2b2b;
    border-radius: 5px;
}

QTabBar::tab {
    background-color: #456b77;
    color: white;
    padding: 10px 20px;
    margin-right: 2px;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
}

QTabBar::tab:selected {
    background-color: #2a9d8f;
}

QLabel {
    color: white;
}

QLineEdit, QComboBox, QSpinBox, QDoubleSpinBox, QDateEdit, QTimeEdit {
    background-color: #3a3a3a;
    color: white;
    border: 1px solid #555;
    padding: 5px;
    border-radius: 3px;
}

QTableWidget {
    background-color: #2b2b2b;
    color: white;
    gridline-color: #555;
    border: 1px solid #2a9d8f;
}

QHeaderView::section {
    background-color: #1e5f74;
    color: white;
    padding: 5px;
    border: none;
    font-weight: bold;
}

QGroupBox {
    color: #2a9d8f;
    font-weight: bold;
    border: 2px solid #2a9d8f;
    border-radius: 5px;
    margin-top: 10px;
    padding-top: 10px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 5px;
}

QCheckBox, QRadioButton {
    color: white;
    padding: 5px;
}

QTextEdit {
    background-color: #3a3a3a;
    color: white;
    border: 1px solid #555;
}</string>
