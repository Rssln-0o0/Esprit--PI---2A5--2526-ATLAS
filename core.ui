                 <string notr="true">QFrame {
	background-color: #232323;
	border-radius: 8px;
    border: 2px solid #3498db;
}
QLabel {
	color: #ffffff;
	font-family: &quot;Segoe UI&quot;;
	font-weight: bold;
	font-size: 12px;
    padding: 2px;
    border: none;
}
QLineEdit, QComboBox, QDateEdit { 
    color: white; 
    background-color: #2d2d2d; 
    border: 1px solid #3d3d3d; 
    padding: 5px; 
    border-radius: 4px; 
    font-family: &quot;Segoe UI&quot;;
    font-weight: bold;
}
QTabWidget::pane { border: 1px solid #3498db; background-color: #232323; border-radius: 5px; }
QTabBar::tab { background: #2d2d2d; color: #ffffff; padding: 10px; border-top-left-radius: 5px; border-top-right-radius: 5px; border: 1px solid #3d3d3d; width: 150px;}
QTabBar::tab:selected { background: #3498db; }</string>
