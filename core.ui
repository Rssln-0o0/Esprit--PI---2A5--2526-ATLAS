              <property name="styleSheet">
               <string notr="true">QTabBar::tab { background: #2d2d2d; color: #ffffff; padding: 10px; border-top-left-radius: 5px; border-top-right-radius: 5px; border: 1px solid #3d3d3d; width: 150px;}
QTabBar::tab:selected { background: #3498db; }
QPushButton {
    background-color: #2a9d8f;
    color: white;
