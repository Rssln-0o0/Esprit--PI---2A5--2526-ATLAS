                <property name="styleSheet">
                 <string notr="true">QFrame#frameSmartPortIoPanel {
    background-color: rgba(30, 41, 59, 0.72);
    border: 1px solid rgba(45, 212, 191, 0.35);
    border-radius: 16px;
}
QFrame#frameSmartPortIoPanel QLabel {
    color: #e2e8f0;
    background: transparent;
}
QFrame#lineSmartPortIoSep {
    background-color: rgba(45, 212, 191, 0.45);
    border: none;
    max-height: 2px;
}
QLabel#lblSmartPortSenHumiditySt,
QLabel#lblSmartPortSenGasSt,
QLabel#lblSmartPortSenFlameSt,
QLabel#lblSmartPortSenMotionSt,
QLabel#lblSmartPortSenRainSt {
    padding: 3px 12px;
    border-radius: 10px;
    background-color: rgba(15, 23, 42, 0.92);
    border: 1px solid rgba(71, 85, 105, 0.75);
    color: #94a3b8;
}
QFrame#frameSmartPortIoPanel QSlider::groove:horizontal {
    height: 7px;
    background: #1e293b;
    border-radius: 4px;
    border: none;
}
QFrame#frameSmartPortIoPanel QSlider::sub-page:horizontal {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #0f766e, stop:1 #2dd4bf);
    border-radius: 4px;
}
QFrame#frameSmartPortIoPanel QSlider::add-page:horizontal {
    background: #334155;
    border-radius: 4px;
}
QFrame#frameSmartPortIoPanel QSlider::handle:horizontal {
    background: #5eead4;
    border: 2px solid #0f766e;
    width: 17px;
    height: 17px;
    margin: -8px 0;
    border-radius: 9px;
}
