          <widget class="QWidget" name="pageQuais">
           <property name="styleSheet">
            <string notr="true">/* Quais module — professional, teal-themed */
#pageQuais QLabel { color: #ffffff; font-weight: bold; }
#pageQuais QLineEdit, 
#pageQuais QComboBox, 
#pageQuais QDateEdit, 
#pageQuais QSpinBox, 
#pageQuais QDoubleSpinBox, 
#pageQuais QTimeEdit {
    background-color: #ffffff;
    color: #2b2b2b;
    border: 1px solid #b7d1db;
    border-radius: 6px;
    padding: 6px 8px;
    min-height: 4px;
    font-size: 13px;
}
#pageQuais QSpinBox, #pageQuais QDoubleSpinBox {
    min-width: 100px;
    padding-left: 8px;
}
#pageQuais QSpinBox::up-button, #pageQuais QSpinBox::down-button,
#pageQuais QDoubleSpinBox::up-button, #pageQuais QDoubleSpinBox::down-button {
    background-color: #e8e8e8;
    border: 1px solid #b7d1db;
    width: 18px;
}
#pageQuais QLineEdit:focus, #pageQuais QComboBox:focus, #pageQuais QSpinBox:focus, #pageQuais QDoubleSpinBox:focus, #pageQuais QDateEdit:focus { border: 1px solid #2a9d8f; }
#pageQuais QHeaderView::section {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #3a3a3a, stop:1 #252525);
    color: #ffffff;
    padding: 12px 14px;
    border: none;
    border-right: 1px solid #454545;
    border-bottom: 2px solid #353535;
    font-weight: bold;
    font-size: 12px;
}
#pageQuais QHeaderView::section:last { border-right: none; }
#pageQuais QTableWidget {
    border-radius: 10px;
    border: 2px solid #2a9d8f;
    background-color: #2b2b2b;
    gridline-color: #3d3d3d;
    padding: 2px;
}
#pageQuais QTableWidget::item { padding: 10px 12px; font-size: 12px; }
#pageQuais QTableWidget::item:alternate { background-color: #323232; }
#pageQuais QTableWidget::item:selected { background-color: #2a9d8f; color: #ffffff; }
#pageQuais QGroupBox {
    color: #2a9d8f;
    font-weight: bold;
    border: 2px solid #2a9d8f;
    border-radius: 8px;
    margin-top: 12px;
    padding: 16px;
    padding-top: 14px;
}
#pageQuais QGroupBox::title {
    subcontrol-origin: margin;
    left: 12px;
    padding: 0 8px;
    font-size: 13px;
}
/* Radio buttons — white text, light gray ring, blue fill when checked (same size as Pecheur Statut) */
#pageQuais QRadioButton {
    color: #ffffff;
    font-size: 12px;
    spacing: 6px;
}
#pageQuais QRadioButton::indicator {
    width: 14px;
    height: 14px;
    border-radius: 7px;
    border: 2px solid #b0b0b0;
    background-color: transparent;
}
#pageQuais QRadioButton::indicator:checked {
    background-color: #3598DB;
    border-color: #b0b0b0;
}
#pageQuais QRadioButton::indicator:hover {
    border-color: #d0d0d0;
}
/* Toolbar — compact, professional */
#pageQuais QPushButton {
    background-color: #2a9d8f;
    color: #ffffff;
    border: none;
    min-width: 72px;
    min-height: 28px;
    padding: 5px 10px;
    border-radius: 4px;
    font-weight: 600;
    font-size: 12px;
}
#pageQuais QPushButton:hover { background-color: #21867a; }
#pageQuais QPushButton:pressed { background-color: #1a6b60; }
#pageQuais QPushButton#btnAdd, #pageQuais QPushButton#btnUpdate { background-color: #3598DB; color: #000000; border: none; min-width: 78px; min-height: 28px; padding: 6px 12px; border-radius: 6px; font-size: 12px; font-weight: bold; }
#pageQuais QPushButton#btnAdd:hover, #pageQuais QPushButton#btnUpdate:hover { background-color: #2980b9; }
#pageQuais QPushButton#btnAdd:pressed, #pageQuais QPushButton#btnUpdate:pressed { background-color: #2471a3; }
#pageQuais QPushButton#btnDelete { background-color: #E74C3C; color: #FFFFFF; border: none; min-width: 78px; min-height: 28px; padding: 6px 12px; border-radius: 6px; font-size: 12px; font-weight: bold; }
#pageQuais QPushButton#btnDelete:hover { background-color: #c0392b; }
#pageQuais QPushButton#btnDelete:pressed { background-color: #a93226; }
#pageQuais QPushButton#btnClear, #pageQuais QPushButton#btnSearch { background-color: #3598DB; color: #000000; border: none; min-width: 78px; min-height: 28px; padding: 6px 12px; border-radius: 6px; font-size: 12px; font-weight: bold; }
#pageQuais QPushButton#btnClear:hover, #pageQuais QPushButton#btnSearch:hover { background-color: #2980b9; }
#pageQuais QPushButton#btnClear:pressed, #pageQuais QPushButton#btnSearch:pressed { background-color: #2471a3; }
#pageQuais QPushButton#btnExport { background-color: #d68910; min-width: 78px; min-height: 28px; padding: 5px 10px; border-radius: 4px; font-size: 12px; }
#pageQuais QPushButton#btnExport:hover { background-color: #b9770e; }
#pageQuais QLineEdit#lineEditSearch { min-width: 140px; padding: 5px 10px; border-radius: 4px; font-size: 12px; }
#pageQuais #labelSmartSort { color: #1e5f74; font-size: 12px; font-weight: 600; }
#pageQuais #comboSmartSort { background-color: #2a2a2a; color: #ffffff; border: 1px solid #3d3d3d; border-radius: 4px; padding: 5px 10px; padding-right: 22px; min-width: 100px; max-width: 160px; font-size: 12px; }
#pageQuais #comboSmartSort:hover { border-color: #2a9d8f; }
#pageQuais #comboSmartSort::drop-down { subcontrol-origin: padding; subcontrol-position: right center; width: 20px; border: none; border-left: 1px solid #3d3d3d; background-color: #252525; border-radius: 0 3px 3px 0; }
/* Supervision / Statistiques tables and cards */
#pageQuais #tableOccupationByType { border-radius: 8px; border: 1px solid #3d3d3d; }
            </string>
           </property>
