            <item>
             <widget class="QTabWidget" name="tabWidget">
              <property name="styleSheet">
               <string notr="true">/* Page background white (same as Pêcheur) */
QTabWidget::pane {
    border: 1px solid #3498db;
    background-color: #ffffff;
    border-radius: 5px;
}
/* Tab bar - same look as Pêcheur buttons (Liste, Statistiques, Missions IA): teal pill-shaped */
QTabWidget#tabWidget QTabBar {
    background-color: transparent;
}
QTabWidget#tabWidget QTabBar::tab {
    background-color: #3CA99C;
    color: #ffffff;
    padding: 6px 14px;
    margin: 4px 6px;
    min-width: 90px;
    border: none;
    border-radius: 8px;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
    font-size: 12px;
    font-weight: bold;
    text-align: center;
}
QTabWidget#tabWidget QTabBar::tab:hover {
    background-color: #36a399;
}
QTabWidget#tabWidget QTabBar::tab:selected {
    background-color: #2d8f85;
    font-weight: bold;
}
/* Global Widget Styles for this Tab */
QWidget {
    font-family: &quot;Segoe UI&quot;;
    background-color: #ffffff;
}
/* Attribute labels inside form - white text, transparent background (same as Pêcheur/Employé) */
QGroupBox QLabel {
    color: #ffffff;
    background: transparent;
    border: none;
    font-family: &quot;Segoe UI&quot;;
    font-weight: bold;
    font-size: 12px;
    padding: 2px;
}
/* Widgets inside form (e.g. Disponibilité row) - same background as form */
QGroupBox QWidget {
    background-color: transparent;
}

/* Radio Buttons */
QRadioButton {
    background-color: transparent;
    color: #e0e0e0;
    font-size: 13px;
}
QRadioButton::indicator {
    width: 14px;
    height: 14px;
    border-radius: 8px;
    border: 2px solid #3b9ddd;
    background-color: transparent;
}
QRadioButton::indicator:checked {
    background-color: #3b9ddd;
    border: 2px solid #3b9ddd;
}

/* GroupBox (Form) - black/dark like Pêcheur */
QGroupBox {
    border: 2px solid #3498db;
    border-radius: 8px;
    margin-top: 10px;
    background-color: #232323;
    font-weight: bold;
    color: #3498db;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top center;
    padding: 0 10px;
    background-color: #232323;
    color: #3498db;
}

/* Inputs inside form */
QLineEdit, QComboBox, QDateEdit, QSpinBox, QPlainTextEdit {
    background-color: #2d2d2d;
    border: 1px solid #3d3d3d;
    border-radius: 6px;
    padding: 8px;
    color: #ffffff;
    min-height: 25px;
}
QLineEdit:focus, QComboBox:focus, QDateEdit:focus {
    border: 1px solid #3498db;
    background-color: #353535;
}

/* Dropdown list (options) - black background, white text */
QComboBox QAbstractItemView {
    background-color: #232323;
    color: #ffffff;
    border: 1px solid #3498db;
    border-radius: 4px;
    padding: 4px;
    selection-background-color: #3498db;
}
QComboBox QAbstractItemView::item {
    min-height: 24px;
}

/* Tri par label and sort combo - dark text on white page so they are clear */
QLabel#label_10 {
    color: #1a3a52;
    background: transparent;
    font-weight: bold;
    font-size: 13px;
}
QComboBox#comboBox_3 {
    color: #1a3a52;
    background-color: #f0f4f8;
    border: 1px solid #3498db;
    border-radius: 6px;
    padding: 8px;
    min-height: 25px;
}

/* Buttons - Ajouter/Modifier: blue + black text; Supprimer: red + white (flat, rounded) */
QPushButton {
    background-color: #3498db;
    color: black;
    border-radius: 6px;
    padding: 8px 16px;
    font-weight: bold;
    border: none;
}
QPushButton:hover {
    background-color: #2980b9;
}
QPushButton:pressed {
    background-color: #21618c;
}

/* Supprimer - red */
QPushButton#pushButton_5 {
    background-color: #e74c3c;
    color: white;
}
QPushButton#pushButton_5:hover {
    background-color: #c0392b;
}
QPushButton#pushButton_5:pressed {
    background-color: #a93226;
}

/* Exporter en PDF - orange */
QPushButton#pushButton_7 {
    background-color: #f39c12;
    color: white;
}
QPushButton#pushButton_7:hover {
    background-color: #f5b041;
}

/* Table Widget (list) - black/dark like Pêcheur */
QTableWidget {
    background-color: #232323;
    alternate-background-color: #2d2d2d;
    gridline-color: #3d3d3d;
    border: 2px solid #3498db;
    border-radius: 8px;
    color: #e0e0e0;
}
QTableWidget::item:selected {
    background-color: #3498db;
    color: white;
}
QHeaderView::section {
    background-color: #2d2d2d;
    color: #ffffff;
    padding: 8px;
    border: none;
    border-bottom: 2px solid #3498db;
    font-weight: bold;
}

/* Frames (table container) - black/dark */
QFrame#chartContainer, QFrame#chartContainer_2 {
    border: 2px solid #3498db;
    border-radius: 8px;
    background-color: #232323;
}

/* Chart View */
QChartView {
    background-color: transparent;
}

/* Menus */
QMenuBar {
    background-color: #1a1a1a;
    color: #e0e0e0;
}
QMenuBar::item:selected {
    background-color: #3b9ddd;
    color: white;
}
QStatusBar {
    background-color: #1a1a1a;
    color: #e0e0e0;
}</string>
