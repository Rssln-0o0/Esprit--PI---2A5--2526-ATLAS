  <property name="styleSheet">
   <string notr="true">/* Main Window */
QMainWindow {
    background-color: #f0f4f8;
}

/* Sidebar */
#sidebar {
    background-color: #1a3a52;
    border-right: 3px solid #0d7377;
}

#lblTitle {
    color: #ffffff;
    font-size: 18px;
    font-weight: bold;
    padding: 10px;
}

/* Common Button Style (Base) */
QPushButton {
    border: none;
    border-radius: 5px;
    font-size: 14px;
    font-weight: 500;
}

/* Sidebar Buttons */
#sidebar QPushButton {
    background-color: #2c5f7d;
    color: #ffffff;
    padding: 15px 20px;
    text-align: left;
    margin: 5px 10px;
    border-left: 4px solid transparent;
}

#sidebar QPushButton:hover {
    background-color: #3e7a9e;
    border-left: 4px solid #14ffec;
}

#sidebar QPushButton:checked {
    background-color: #0d7377;
    border-left: 6px solid #14ffec;
    font-weight: bold;
}

/* Sub-navigation Bar Container */
#subNavBar {
    background-color: transparent;
}

/* Sub-navigation Buttons */
#subNavBar QPushButton {
    background-color: #2c5f7d;
    color: #ffffff;
    padding: 8px 15px;
    text-align: center;
    margin: 5px;
    min-width: 120px;
    border-bottom: 3px solid transparent;
}

#subNavBar QPushButton:hover {
    background-color: #3e7a9e;
    border-bottom: 3px solid #14ffec;
}

#subNavBar QPushButton:checked {
    background-color: #0d7377;
    border-bottom: 4px solid #14ffec;
    font-weight: bold;
}

/* Pecheur Sub-navigation Bar */
#subNavBarPecheurs {
    background-color: transparent;
}

#subNavBarPecheurs QPushButton {
    background-color: #3CA99C;
    color: #ffffff;
    padding: 0 14px;
    text-align: center;
    margin: 4px 6px;
    min-width: 90px;
    min-height: 30px;
    border: none;
    border-radius: 8px;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
    font-size: 13px;
    font-weight: bold;
}

#subNavBarPecheurs QPushButton:hover {
    background-color: #36a399;
}

#subNavBarPecheurs QPushButton:checked {
    background-color: #2d8f85;
    font-weight: bold;
}

/* Page Titles */
.pageTitle {
    color: #1a3a52;
    font-size: 28px;
    font-weight: bold;
}

.subPageTitle {
    color: #2c5f7d;
    font-size: 24px;
    font-weight: 600;
}

/* Global polish */
QWidget {
    font-family: &quot;Segoe UI&quot;, &quot;Noto Sans&quot;, sans-serif;
}

QFrame {
    border-radius: 10px;
}

QLineEdit, QComboBox, QDateEdit, QSpinBox, QDoubleSpinBox, QTimeEdit, QPlainTextEdit {
    min-height: 30px;
    padding: 4px 6px;
}

QTableWidget, QTableView {
    background-color: #27323b;
    color: #f3f6f8;
    gridline-color: #41515f;
    alternate-background-color: #31414d;
    selection-background-color: #1f8ca1;
}

QTableWidget::item, QTableView::item {
    min-height: 24px;
}

QLineEdit:focus, QComboBox:focus, QDateEdit:focus, QSpinBox:focus, QDoubleSpinBox:focus, QTimeEdit:focus {
    border: 1px solid #1f8ca1;
}

QPushButton:disabled {
    background-color: #6d7f8d;
    color: #dbe3e9;
}

QHeaderView::section {
    min-height: 28px;
    font-size: 12px;
}</string>
